{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "rootDir": ".",
    "outDir": ".test-dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"],
    "resolveJsonModule": true,
    "noEmit": false
  },
  "include": [
    "src/lib/formatters.ts",
    "src/lib/transaction-utils.ts",
    "tests/**/*.ts"
  ]
}
